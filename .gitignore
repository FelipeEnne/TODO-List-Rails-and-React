# See https://help.github.com/articles/ignoring-files for more about ignoring files.

/.bundle
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/storage/*
!/storage/.keep

/node_modules
/yarn-error.log
yarn-debug.log*
.yarn-integrity

/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

/config/master.key
